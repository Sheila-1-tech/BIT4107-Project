class PatientModel {
  final int? id;
  final String fullName;
  final String phone;
  final String dateOfBirth;
  final String allergies;

  PatientModel({
    this.id,
    required this.fullName,
    required this.phone,
    required this.dateOfBirth,
    required this.allergies,
  });

  Map<String, dynamic> toMap() {
    final map = <String, dynamic>{
      'fullName': fullName,
      'phone': phone,
      'dateOfBirth': dateOfBirth,
      'allergies': allergies,
    };
    if (id != null) {
      map['id'] = id;
    }
    return map;
  }

  factory PatientModel.fromMap(Map<String, dynamic> map) {
    return PatientModel(
      id: map['id'] as int?,
      fullName: map['fullName'] as String,
      phone: map['phone'] as String,
      dateOfBirth: map['dateOfBirth'] as String,
      allergies: map['allergies'] as String,
    );
  }
}

class DispenseRecordModel {
  final int? id;
  final int patientId;
  final String patientName;
  final String medicationName;
  final int quantity;
  final String timestamp;

  DispenseRecordModel({
    this.id,
    required this.patientId,
    required this.patientName,
    required this.medicationName,
    required this.quantity,
    required this.timestamp,
  });

  Map<String, dynamic> toMap() {
    final map = <String, dynamic>{
      'patientId': patientId,
      'patientName': patientName,
      'medicationName': medicationName,
      'quantity': quantity,
      'timestamp': timestamp,
    };
    if (id != null) {
      map['id'] = id;
    }
    return map;
  }

  factory DispenseRecordModel.fromMap(Map<String, dynamic> map) {
    return DispenseRecordModel(
      id: map['id'] as int?,
      patientId: map['patientId'] as int,
      patientName: map['patientName'] as String,
      medicationName: map['medicationName'] as String,
      quantity: map['quantity'] as int,
      timestamp: map['timestamp'] as String,
    );
  }
}

// ============================================================================
// DATABASE LOGIC (CRUD)
// ============================================================================

class PharmacyManagementDB {
  static final PharmacyManagementDB instance = PharmacyManagementDB._init();
  static Database? _database;
  static Future<Database>? _databaseFuture;

  // Track if we should bypass SQLite entirely (Web, Windows, or if init fails)
  bool _useInMemory = kIsWeb;

  // In-memory fallback for Web support
  final List<PatientModel> _webPatients = [];
  final List<DispenseRecordModel> _webRecords = [];
  int _webPatientIdCounter = 1;
  int _webRecordIdCounter = 1;

  PharmacyManagementDB._init();

  Future<Database> get database async {
    if (_useInMemory)
      throw UnsupportedError('SQLite is disabled, using in-memory mode.');
    if (_database != null) return _database!;
    _databaseFuture ??= _initDB('pharmacy_management_module.db');
    try {
      _database = await _databaseFuture!;
      return _database!;
    } catch (e) {
      _useInMemory = true;
      throw UnsupportedError(
        'SQLite init failed, switching to in-memory mode.',
      );
    }
  }

  Future<Database> _initDB(String filePath) async {
    final dbPath = await getDatabasesPath();
    final path = p.join(dbPath, filePath);
    return await openDatabase(path, version: 1, onCreate: _createDB);
  }

  Future<void> _createDB(Database db, int version) async {
    await db.execute('''
      CREATE TABLE patients_module (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        fullName TEXT NOT NULL,
        phone TEXT NOT NULL,
        dateOfBirth TEXT NOT NULL,
        allergies TEXT NOT NULL
      )
    ''');

    await db.execute('''
      CREATE TABLE dispensing_records (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        patientId INTEGER NOT NULL,
        patientName TEXT NOT NULL,
        medicationName TEXT NOT NULL,
        quantity INTEGER NOT NULL,
        timestamp TEXT NOT NULL,
        FOREIGN KEY (patientId) REFERENCES patients_module (id)
      )
    ''');
  }

  // --- Patient CRUD ---
  Future<void> insertPatient(PatientModel patient) async {
    if (!_useInMemory) {
      try {
        final db = await instance.database;
        await db.insert('patients_module', patient.toMap());
        return;
      } catch (e) {
        _useInMemory = true;
      }
    }

    // In-memory fallback
    _webPatients.add(
      PatientModel(
        id: _webPatientIdCounter++,
        fullName: patient.fullName,
        phone: patient.phone,
        dateOfBirth: patient.dateOfBirth,
        allergies: patient.allergies,
      ),
    );
  }

  Future<List<PatientModel>> getAllPatients() async {
    if (!_useInMemory) {
      try {
        final db = await instance.database;
        final result = await db.query(
          'patients_module',
          orderBy: 'fullName ASC',
        );
        return result.map((json) => PatientModel.fromMap(json)).toList();
      } catch (e) {
        _useInMemory = true;
      }
    }
    return List.unmodifiable(_webPatients);
  }

  // --- Dispensing Records CRUD ---
  Future<void> insertDispenseRecord(DispenseRecordModel record) async {
    if (!_useInMemory) {
      try {
        final db = await instance.database;
        await db.insert('dispensing_records', record.toMap());
        return;
      } catch (e) {
        _useInMemory = true;
      }
    }

    _webRecords.add(
      DispenseRecordModel(
        id: _webRecordIdCounter++,
        patientId: record.patientId,
        patientName: record.patientName,
        medicationName: record.medicationName,
        quantity: record.quantity,
        timestamp: record.timestamp,
      ),
    );
  }

  Future<List<DispenseRecordModel>> getDispenseRecords({DateTime? date}) async {
    if (!_useInMemory) {
      try {
        final db = await instance.database;
        String? whereClause;
        List<dynamic>? whereArgs;

        if (date != null) {
          final dateString = date.toIso8601String().substring(0, 10);
          whereClause = 'timestamp LIKE ?';
          whereArgs = ['$dateString%'];
        }

        final result = await db.query(
          'dispensing_records',
          where: whereClause,
          whereArgs: whereArgs,
          orderBy: 'timestamp DESC',
        );
        return result.map((json) => DispenseRecordModel.fromMap(json)).toList();
      } catch (e) {
        _useInMemory = true;
      }
    }

    var records = _webRecords;
    if (date != null) {
      final dateString = date.toIso8601String().substring(0, 10);
      records = records
          .where((r) => r.timestamp.startsWith(dateString))
          .toList();
    }
    return records.reversed.toList();
  }

  // --- Delete Operations ---
  Future<void> deletePatient(int id) async {
    if (!_useInMemory) {
      try {
        final db = await instance.database;
        await db.delete('patients_module', where: 'id = ?', whereArgs: [id]);
        await db.delete(
          'dispensing_records',
          where: 'patientId = ?',
          whereArgs: [id],
        );
        return;
      } catch (e) {
        _useInMemory = true;
      }
    }
    _webPatients.removeWhere((p) => p.id == id);
    _webRecords.removeWhere((r) => r.patientId == id);
  }

  Future<void> deleteDispenseRecord(int id) async {
    if (!_useInMemory) {
      try {
        final db = await instance.database;
        await db.delete('dispensing_records', where: 'id = ?', whereArgs: [id]);
        return;
      } catch (e) {
        _useInMemory = true;
      }
    }
    _webRecords.removeWhere((r) => r.id == id);
  }
}

